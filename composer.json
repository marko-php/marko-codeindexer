{
    "name": "marko/codeindexer",
    "description": "Shared static-analysis library for Marko AI tooling",
    "license": "MIT",
    "type": "marko-module",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "nikic/php-parser": "^5.4"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\CodeIndexer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\CodeIndexer\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
